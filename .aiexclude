# =========================================================================
# 1. 秘密情報・環境変数（最重要：セキュリティ対策）
# =========================================================================
.env
.env.*
!.env.example
*.pem
*.key

# =========================================================================
# 2. 巨大な依存関係（ノイズ削減・トークン節約）
# =========================================================================
node_modules/
.pnpm-store/
.yarn/

# =========================================================================
# 3. ビルド成果物・自動生成ファイル（AIが読む必要がないもの）
# =========================================================================
dist/
build/
.next/
out/
.nuxt/
.cache/
.turbo/

# =========================================================================
# 4. ログ・キャッシュ・テストレポート
# =========================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
coverage/
.nyc_output/

# =========================================================================
# 5. OSやエディタの一時ファイル（共有不要なもの）
# =========================================================================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
